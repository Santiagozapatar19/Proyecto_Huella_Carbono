# ─────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores
# cp .env.example .env
# ─────────────────────────────────────────────

# Django
SECRET_KEY=django-insecure-cambia-esto-en-produccion-generalo-con-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (SQLite por defecto para desarrollo)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Para PostgreSQL (descomentar y llenar):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=huella_carbono_db
# DB_USER=postgres
# DB_PASSWORD=tu_password
# DB_HOST=localhost
# DB_PORT=5432

# CORS (orígenes permitidos para el frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
